{
  "hooks": [
    {
      "event": "SessionStart",
      "triggers": ["startup", "clear"],
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh",
      "timeout": 10000,
      "statusMessage": "Loading knowledge base..."
    },
    {
      "event": "SessionStart",
      "triggers": ["compact"],
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-compaction.sh",
      "timeout": 10000,
      "statusMessage": "Recovering knowledge context..."
    },
    {
      "event": "UserPromptSubmit",
      "triggers": ["user"],
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/user-prompt-submit.sh",
      "timeout": 3000
    },
    {
      "event": "SubagentStop",
      "triggers": ["*"],
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/subagent-stop.sh",
      "timeout": 10000,
      "async": true
    },
    {
      "event": "Stop",
      "triggers": ["*"],
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-stop.sh",
      "timeout": 5000,
      "async": true
    }
  ]
}
